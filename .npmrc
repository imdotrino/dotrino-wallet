# No ejecutar lifecycle scripts de dependencias (preinstall/install/postinstall):
# vector #1 de inyección. Verificado: vite/esbuild funcionan igual.
ignore-scripts=true
# Instalar versiones EXACTAS (sin ^ ni ~): evita drift a un release recién
# publicado y potencialmente comprometido. El package-lock.json manda.
save-exact=true
fund=false
